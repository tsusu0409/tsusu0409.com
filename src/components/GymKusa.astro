---
import gymStats from '../data/gym-checkins.json';

interface Entry {
  date: string;
  treadmill_km: number;
}

const kmByDate: Record<string, number> = {};
(gymStats as Entry[]).forEach((entry) => {
  const utc = new Date(entry.date);
  const jstShifted = new Date(utc.getTime() + (9 - 4) * 60 * 60 * 1000);
  const key = jstShifted.toISOString().slice(0, 10);
  kmByDate[key] = Math.round(((kmByDate[key] ?? 0) + entry.treadmill_km) * 10) / 10;
});

const today = new Date();
const dayOfWeek = today.getDay();
const endDate = new Date(today);
endDate.setDate(endDate.getDate() + (6 - dayOfWeek));

const startDate = new Date(endDate);
startDate.setDate(startDate.getDate() - 52 * 7 + 1);

interface DayCell {
  key: string;
  km: number;
  isFuture: boolean;
}

const weeks: DayCell[][] = [];
const cur = new Date(startDate);
const todayKey = today.toISOString().slice(0, 10);

while (cur <= endDate) {
  const week: DayCell[] = [];
  for (let d = 0; d < 7; d++) {
    const key = cur.toISOString().slice(0, 10);
    week.push({
      key,
      km: kmByDate[key] ?? 0,
      isFuture: key > todayKey,
    });
    cur.setDate(cur.getDate() + 1);
  }
  weeks.push(week);
}

interface MonthLabel {
  label: string;
  spanWeeks: number;
}
const monthLabels: MonthLabel[] = [];
const MONTHS = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
let lastMonth = -1;
weeks.forEach((week) => {
  const m = new Date(week[0].key).getMonth();
  if (m !== lastMonth) {
    monthLabels.push({ label: MONTHS[m], spanWeeks: 0 });
    lastMonth = m;
  }
  monthLabels[monthLabels.length - 1].spanWeeks++;
});

const allKm = Object.values(kmByDate);
const totalKm = allKm.reduce((a, b) => a + b, 0);
const activeDays = allKm.filter((v) => v > 0).length;
const maxKm = allKm.length > 0 ? Math.max(...allKm) : 0;

function kmToColorClass(km: number, isFuture: boolean): string {
  if (isFuture) return 'bg-neutral-100';
  if (km === 0)  return 'bg-neutral-200';
  if (km < 2)  return 'bg-green-200';
  if (km < 3.5)    return 'bg-green-300';
  if (km < 5)  return 'bg-green-500';
  if (km < 6.5)    return 'bg-green-700';
  return           'bg-green-900';
}

const DAYS_JA = ['日','月','火','水','木','金','土'];
const CELL_SIZE = 13;
const CELL_GAP  = 3;
---

<section class="py-4 sm:py-6 font-mono w-full">

  <div class="grid grid-cols-2 gap-3 mb-5 sm:flex sm:gap-8">
    <div>
      <p class="text-xl sm:text-2xl font-medium text-neutral-900 leading-none">
        {totalKm.toFixed(1)}<span class="text-xs sm:text-sm font-normal text-neutral-400 ml-1">km</span>
      </p>
      <p class="text-[10px] sm:text-xs text-neutral-400 mt-1">過去1年の走行距離</p>
    </div>
    <div>
      <p class="text-xl sm:text-2xl font-medium text-neutral-900 leading-none">{activeDays}</p>
      <p class="text-[10px] sm:text-xs text-neutral-400 mt-1">ジム訪問日数</p>
    </div>
    <div>
      <p class="text-xl sm:text-2xl font-medium text-neutral-900 leading-none">
        {maxKm.toFixed(1)}<span class="text-xs sm:text-sm font-normal text-neutral-400 ml-1">km</span>
      </p>
      <p class="text-[10px] sm:text-xs text-neutral-400 mt-1">最長距離 / 日</p>
    </div>
  </div>

  <div id="gym-kusa-wrapper" class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0">
    <div class="min-w-max">

      <div class="flex mb-1 pl-[22px]">
        {monthLabels.map((ml) => {
          const width = ml.spanWeeks * (CELL_SIZE + CELL_GAP) - CELL_GAP;
          return (
            <div
              style={`width:${width}px; flex-shrink:0;`}
              class="text-[10px] text-neutral-400 overflow-hidden"
            >
              {ml.label}
            </div>
          );
        })}
      </div>

      <div class="flex">
        <div class="flex flex-col gap-[3px] mr-1 shrink-0">
          {DAYS_JA.map((d, i) => (
            <div class="text-[10px] text-neutral-400 h-[13px] leading-[13px] w-[18px] text-right pr-1">
              {i % 2 === 1 ? d : ''}
            </div>
          ))}
        </div>

        <div class="flex gap-[3px]" id="gym-kusa-grid">
          {weeks.map((week) => (
            <div class="flex flex-col gap-[3px]">
              {week.map((day) => (
                <div
                  class={[
                    'w-[13px] h-[13px] rounded-sm cursor-pointer transition-opacity hover:opacity-70',
                    kmToColorClass(day.km, day.isFuture),
                  ].join(' ')}
                  data-date={day.key}
                  data-km={day.km}
                  aria-label={day.km > 0 ? `${day.key}: ${day.km.toFixed(1)}km` : `${day.key}: rest`}
                />
              ))}
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>

  <div class="flex items-center gap-1.5 mt-3 text-[10px] sm:text-[11px] text-neutral-400">
    <span>少ない</span>
    <div class="w-[11px] h-[11px] sm:w-[13px] sm:h-[13px] rounded-sm bg-neutral-200" />
    <div class="w-[11px] h-[11px] sm:w-[13px] sm:h-[13px] rounded-sm bg-green-200" />
    <div class="w-[11px] h-[11px] sm:w-[13px] sm:h-[13px] rounded-sm bg-green-300" />
    <div class="w-[11px] h-[11px] sm:w-[13px] sm:h-[13px] rounded-sm bg-green-500" />
    <div class="w-[11px] h-[11px] sm:w-[13px] sm:h-[13px] rounded-sm bg-green-700" />
    <div class="w-[11px] h-[11px] sm:w-[13px] sm:h-[13px] rounded-sm bg-green-900" />
    <span>多い</span>
    <span class="ml-2 text-neutral-300">km / day</span>
  </div>

</section>

<div
  id="gym-kusa-tooltip"
  class="fixed hidden z-50 pointer-events-none bg-white border border-neutral-200 rounded-md px-3 py-1.5 text-xs text-neutral-700 whitespace-nowrap shadow-sm"
/>

<script>
  // 初期表示を右端（最新日）にスクロール
  const wrapper = document.getElementById('gym-kusa-wrapper');
  if (wrapper) {
    wrapper.scrollLeft = wrapper.scrollWidth;
  }

  const grid = document.getElementById('gym-kusa-grid');
  const tooltip = document.getElementById('gym-kusa-tooltip');

  if (grid && tooltip) {
    grid.addEventListener('mouseover', (e) => {
      const cell = (e.target as HTMLElement).closest('[data-date]') as HTMLElement | null;
      if (!cell) return;

      const date = cell.dataset.date ?? '';
      const km   = parseFloat(cell.dataset.km ?? '0');
      tooltip.textContent = km > 0
        ? `${date} — ${km.toFixed(1)} km`
        : `${date} — rest day`;

      const cellRect = cell.getBoundingClientRect();
      tooltip.style.left = `${cellRect.left}px`;
      tooltip.style.top  = `${cellRect.top - 36}px`;
      tooltip.classList.remove('hidden');
    });

    grid.addEventListener('mouseleave', () => {
      tooltip.classList.add('hidden');
    });
  }
</script>